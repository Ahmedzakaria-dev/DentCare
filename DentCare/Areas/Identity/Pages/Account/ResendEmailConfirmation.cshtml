@{
    ViewData["Title"] = "Register confirmation";
}

<div class="container d-flex justify-content-center align-items-center py-5" style="min-height: calc(100vh - 120px);">
    <div class="card text-center p-4 shadow-lg border-0" style="
        background-color: #1e1e2f;
        color: white;
        border-radius: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 0 20px rgba(0,255,255,0.1);
        cursor: pointer;"
         onmouseover="this.style.transform='scale(1.03)'; this.style.boxShadow='0 0 30px rgba(0,255,255,0.3)';"
         onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 20px rgba(0,255,255,0.1)';"
         onclick="this.style.transform='scale(0.98)'; setTimeout(() => this.style.transform='scale(1.03)', 150);">

        <div class="d-flex flex-column align-items-center" style="gap: 15px;">
            <img src="https://cdn-icons-png.flaticon.com/512/845/845646.png" alt="Confirmed" style="width: 50px;">
            <h2 class="mb-0">Register confirmation</h2>
        </div>

        <p class="mt-3">
            This app does not currently have a real email sender registered, see
            <a href="https://aka.ms/aspaccountconf" target="_blank" style="color: #00cfff;">these docs</a>
            for how to configure a real email sender.
        </p>

        <p>Normally this would be emailed:</p>

        <a class="btn mt-3 px-4" style="background-color: #00cfff; color: white; border-radius: 10px; transition: background-color 0.3s ease, box-shadow 0.3s ease;"
           asp-page="./ConfirmEmail"
           asp-route-userId="@Model.UserId"
           asp-route-code="@Model.Code">
            Confirm your account
        </a>
    </div>
</div>

<footer class="text-center py-3" style="color: #888; font-size: 0.9rem;">
    © 2024 - team - <a href="/Privacy" class="text-info text-decoration-none">Privacy</a>
</footer>

<style>
    a.btn:hover {
        background-color: #00b5e2;
        box-shadow: 0 0 12px rgba(0,207,255,0.4);
    }

    a.btn:active {
        transform: scale(0.96);
    }
</style>
