@page
@model DentCare.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    html, body {
        margin: 0;
        padding: 0;
        width: 100vw;
        height: 100vh;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background-image: url('/images/1.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        overflow: hidden;
    }

    footer {
        display: none !important;
    }

    .main-wrapper {
        width: 100vw;
        height: calc(100vh - 56px);
        position: relative;
        perspective: 1500px; 
    }

    .tablet-frame {
        position: absolute;
        left: 18.2vw; 
        top: 50%;
        transform: translateY(-50%) rotateY(13deg) rotateX(4deg) rotateZ(-0.8deg);
        transform-style: preserve-3d;
        background: rgba(2, 6, 9, 0.5) !important; 
        backdrop-filter: blur(16px) cubic-bezier(0.4, 0, 0.2, 1);
        -webkit-backdrop-filter: blur(16px) cubic-bezier(0.4, 0, 0.2, 1);
        border: none !important; 
        box-shadow: none !important; 
        width: 21vw; 
        min-width: 320px;
        max-width: 360px;
        transition: transform 0.3s ease;
        border-radius: 20px;
    }

    .tablet-frame:hover {
        transform: translateY(-51%) rotateY(8deg) rotateX(2deg) rotateZ(-0.5deg) scale(1.01);
    }

    .form-content {
        width: 100%;
        background: transparent !important; 
        padding: 25px 20px;
    }

    .form-content h2 {
        margin-bottom: 25px;
        color: #ffffff;
        font-weight: 600;
        text-align: center;
        font-size: 1.5rem;
        letter-spacing: 0.3px;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
    }

    .custom-group {
        position: relative;
        margin-bottom: 15px;
    }

    .custom-field {
        width: 100%;
        height: 45px;
        border-radius: 6px;
        border: 1px solid rgba(0, 229, 255, 0.35) !important; 
        background-color: rgba(3, 10, 16, 0.75) !important; 
        color: #ffffff !important; 
        padding: 0 40px 0 14px !important;
        font-size: 0.9rem;
        transition: all 0.25s ease;
    }

    .custom-field:focus {
        border-color: #00e5ff !important;
        background-color: rgba(4, 14, 23, 0.9) !important;
        box-shadow: 0 0 10px rgba(0, 229, 255, 0.45) !important;
        outline: none;
    }

    .custom-placeholder {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.55) !important; 
        pointer-events: none;
        transition: all 0.2s ease;
        font-size: 0.9rem;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
    }

    .custom-field:focus ~ .custom-placeholder,
    .custom-field:not(:placeholder-shown) ~ .custom-placeholder {
        opacity: 0;
    }

    .password-toggle {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: rgba(0, 229, 255, 0.6);
        font-size: 0.95rem;
        z-index: 5;
    }

    .btn-login {
        background: linear-gradient(180deg, #00f0ff, #00b4db);
        border: none;
        font-weight: 600;
        border-radius: 6px;
        color: #020710;
        padding: 10px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        box-shadow: 0 0 15px rgba(0, 240, 255, 0.45);
        margin-top: 5px;
    }

    .btn-google {
        background: rgba(255, 255, 255, 0.9) !important;
        border: none;
        color: #111 !important;
        font-weight: 600;
        border-radius: 6px;
        padding: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.88rem;
    }

    .btn-google img {
        margin-right: 8px;
    }

    .form-links a {
        color: rgba(255, 255, 255, 0.6); 
        text-decoration: none;
        font-size: 0.85rem;
        display: block;
        margin-top: 8px;
        transition: color 0.2s ease;
    }

    .form-links a:hover {
        color: #00e5ff;
    }

    @@media (max-width: 992px) {
        html, body { overflow: auto; background-position: right center; }
        .main-wrapper { height: auto; min-height: calc(100vh - 56px); display: flex; justify-content: center; align-items: center; }
        .tablet-frame { position: relative; left: 0; top: 0; transform: none; margin: 20px 15px; width: 100%; background: rgba(2, 6, 9, 0.9) !important; }
    }
</style>

<div class="main-wrapper">
    <div class="tablet-frame">
        <div class="form-content">
            <h2>Welcome Back!</h2>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="custom-group">
                    <input asp-for="Input.Email" class="custom-field" placeholder=" " autocomplete="username" aria-required="true" />
                    <label asp-for="Input.Email" class="custom-placeholder">Email or Username</label>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.75rem;"></span>
                </div>

                <div class="custom-group">
                    <input asp-for="Input.Password" type="password" id="passwordInput" class="custom-field" placeholder=" " autocomplete="current-password" aria-required="true" />
                    <label asp-for="Input.Password" class="custom-placeholder">Password</label>
                    <i class="bi bi-eye-slash password-toggle" id="togglePassword"></i>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.75rem;"></span>
                </div>

                <div class="checkbox mb-3 ms-1">
                    <label asp-for="Input.RememberMe" class="text-light" style="font-size: 0.85rem; cursor: pointer;">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="background-color: rgba(3, 10, 16, 0.75); border-color: rgba(0, 229, 255, 0.35);" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-login">Log in</button>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center my-2">
                    <span style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">or</span>
                </div>
                <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <button type="submit" class="btn btn-google w-100" name="provider" value="Google">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="16" />
                        Log in with Google
                    </button>
                </form>
            }

            <div class="form-links text-center mt-3">
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#passwordInput');

        togglePassword.addEventListener('click', function () {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            this.classList.toggle('bi-eye');
            this.classList.toggle('bi-eye-slash');
        });
    </script>
}