@page
@model LockoutModel
@{
    ViewData["Title"] = "Locked out";
}

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fdfcf9;
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .lockout-box {
        background-color: #fff;
        padding: 50px;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        text-align: center;
        max-width: 600px;
        width: 100%;
    }

        .lockout-box h1 {
            color: #e74c3c;
            font-size: 2rem;
            margin-bottom: 20px;
        }

        .lockout-box p {
            color: #555;
            font-size: 1.1rem;
        }

    .icon-lock {
        font-size: 3rem;
        color: #e74c3c;
        margin-bottom: 20px;
    }
</style>

<div class="lockout-box">
    <div class="icon-lock">
        🔒
    </div>
    <h1>@ViewData["Title"]</h1>
    <p>This account has been locked out. Please try again later or contact support if the issue persists.</p>
</div>
