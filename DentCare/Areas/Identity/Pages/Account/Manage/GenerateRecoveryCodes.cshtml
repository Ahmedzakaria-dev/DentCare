@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Generate 2FA Recovery Codes";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="mb-4">
    <h2 class="mb-3">@ViewData["Title"]</h2>
    <p class="text-muted">You can generate recovery codes to use when you lose access to your authenticator app.</p>
</div>

<div class="alert alert-warning border-start border-4 border-warning-subtle shadow-sm" role="alert">
    <h5 class="mb-2"><i class="bi bi-exclamation-triangle-fill text-warning"></i> Keep these codes safe!</h5>
    <ul class="mb-0 ps-3">
        <li>These codes are your last resort to access your account if you lose your device.</li>
        <li>They do not reset your authenticator keys.</li>
        <li>If you want to change the key used by your authenticator app, <a asp-page="./ResetAuthenticator">reset your keys here</a>.</li>
    </ul>
</div>

<div class="text-center mt-4">
    <form method="post">
        <button class="btn btn-lg btn-danger shadow-sm px-4" type="submit">
            <i class="bi bi-shield-lock-fill me-2"></i>Generate Recovery Codes
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
