@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fdfcf9;
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    .logout-box {
        background-color: #fff;
        padding: 40px;
        border-radius: 16px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        text-align: center;
        max-width: 500px;
        width: 100%;
    }

        .logout-box h1 {
            color: #2c3e50;
            margin-bottom: 20px;
        }

    .btn-sika-blue {
        background-color: #2980b9;
        border-color: #2980b9;
        font-weight: bold;
        border-radius: 8px;
        color: #fff;
        padding: 10px 20px;
        margin-top: 20px;
        transition: 0.3s ease;
    }

        .btn-sika-blue:hover {
            background-color: #21618c;
            border-color: #21618c;
        }

    p {
        color: #555;
        font-size: 1.1rem;
    }
</style>

<div class="logout-box">
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-sika-blue">Click here to Logout</button>
            </form>
        }
        else
        {
            <p>You have successfully logged out of the application.</p>
        }
    }
</div>
