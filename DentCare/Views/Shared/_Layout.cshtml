@using Utility
@using Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DentCare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <style>
            html, body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                background-image: url('/images/1.png');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                background-attachment: fixed;
                color: #ffffff;
            }

            .navbar-custom {
                background: rgba(1, 4, 7, 0.9) !important;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(0, 229, 255, 0.2);
                z-index: 1050;
            }

                .navbar-custom .nav-link, .navbar-custom .navbar-brand {
                    color: #ffffff !important;
                    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
                }

                    .navbar-custom .nav-link:hover {
                        color: #00e5ff !important;
                    }

            .custom-dropdown-menu {
                background: #010407 !important;
                border: 1px solid rgba(0, 229, 255, 0.4) !important;
                border-radius: 8px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8) !important;
                z-index: 9999 !important;
                min-width: 200px;
            }

            .dropdown-item {
                color: #ffffff !important;
                transition: all 0.2s ease;
                border-radius: 4px;
                padding: 8px 16px;
            }

                .dropdown-item:hover {
                    background: rgba(0, 229, 255, 0.2) !important;
                    color: #00e5ff !important;
                }

            .dropdown-toggle::after {
                vertical-align: middle;
            }

            .glass-card {
                background: rgba(2, 6, 12, 0.75) !important;
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(0, 229, 255, 0.25) !important;
                border-radius: 16px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.75);
                color: #ffffff;
                padding: 30px;
                margin-top: 30px;
                position: relative;
                z-index: 1;
            }

            .glass-title {
                color: #00e5ff;
                font-weight: 600;
                text-shadow: 0 0 12px rgba(0, 229, 255, 0.6), 0 2px 4px rgba(0,0,0,0.9);
                margin-bottom: 25px;
            }

            .lead.text-muted {
                color: rgba(255, 255, 255, 0.85) !important;
                text-shadow: 0 2px 4px rgba(0, 0, 0, 1), 0 0 10px rgba(0, 0, 0, 0.8);
                font-weight: 500;
            }

            .row.text-center .col-md-3 > div {
                background: rgba(1, 4, 8, 0.88) !important;
                border: 1px solid rgba(0, 229, 255, 0.3) !important;
                backdrop-filter: blur(12px);
                box-shadow: 0 12px 28px rgba(0, 0, 0, 0.65);
                transition: transform 0.2s ease;
            }

                .row.text-center .col-md-3 > div:hover {
                    transform: translateY(-3px);
                    border-color: #00e5ff !important;
                }

            .row.text-center h2 {
                color: #ffffff !important;
                text-shadow: 0 2px 8px rgba(0, 0, 0, 0.95);
                font-weight: 700;
            }

            .row.text-center small {
                color: #00e5ff !important;
                font-weight: 700;
                letter-spacing: 0.8px;
                text-shadow: 0 2px 5px rgba(0, 0, 0, 1), 0 0 8px rgba(0, 0, 0, 0.9);
            }

            .text-muted.py-3 {
                color: rgba(255, 255, 255, 0.7) !important;
                text-shadow: 0 1px 4px rgba(0, 0, 0, 0.9);
                font-weight: 500;
            }

            .glass-input {
                background-color: rgba(3, 10, 16, 0.85) !important;
                border: 1px solid rgba(0, 229, 255, 0.35) !important;
                color: #ffffff !important;
                border-radius: 6px;
                height: 42px;
            }

                .glass-input:focus {
                    border-color: #00e5ff !important;
                    box-shadow: 0 0 10px rgba(0, 229, 255, 0.45) !important;
                    background-color: rgba(4, 14, 23, 0.95) !important;
                    outline: none;
                }

            .btn-neon-cyan {
                background: linear-gradient(180deg, #00f0ff, #00b4db);
                border: none;
                font-weight: 600;
                border-radius: 6px;
                color: #020710;
                transition: all 0.3s ease;
                box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
            }

                .btn-neon-cyan:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 0 25px rgba(0, 240, 255, 0.7);
                    color: #020710;
                }

            .btn-neon-cancel {
                background: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                color: #ffffff;
                border-radius: 6px;
                transition: all 0.3s ease;
            }

                .btn-neon-cancel:hover {
                    background: rgba(255, 255, 255, 0.2);
                    color: #ffffff;
                }

            .btn-neon-danger {
                background: linear-gradient(180deg, #e74c3c, #c0392b);
                border: none;
                font-weight: 600;
                color: #fff;
                border-radius: 6px;
                transition: all 0.3s ease;
                box-shadow: 0 0 15px rgba(231, 76, 60, 0.3);
            }

                .btn-neon-danger:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 0 20px rgba(231, 76, 60, 0.6);
                    color: #fff;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand font-weight-bold" asp-area="" asp-controller="Home" asp-action="Index">DentCare</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation" style="border-color: rgba(0,229,255,0.3);">
                    <span class="bi bi-list" style="color: #00e5ff; font-size: 1.5rem;"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Doctors">Doctors</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Services">Services</a></li>
                        
                        @if (!SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About Us</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown me-3 position-relative">
                                <a class="nav-link dropdown-toggle btn btn-neon-cyan px-3 py-1 text-dark d-flex align-items-center"
                                       href="#" id="navbarDropdownMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                                       style="color: #020710 !important; font-weight: 600;">
                                    <i class="bi bi-grid-3x3-gap-fill me-1"></i> Menu
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end custom-dropdown-menu p-2 mt-2" aria-labelledby="navbarDropdownMenu">
                                    @if (User.IsInRole(SD.Admin))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2 text-info"></i>Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Clinic" asp-action="Index"><i class="bi bi-building me-2 text-info"></i>Clinics</a></li>
                                        <li><a class="dropdown-item" asp-controller="Doctor" asp-action="Index"><i class="bi bi-person-badge me-2 text-info"></i>Doctors</a></li>
                                        <li><a class="dropdown-item" asp-controller="Department" asp-action="Index"><i class="bi bi-diagram-3 me-2 text-info"></i>Departments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Treatment" asp-action="Index"><i class="bi bi-activity me-2 text-info"></i>Treatments</a></li>
                                        <li><a class="dropdown-item" asp-controller="User" asp-action="Index"><i class="bi bi-people me-2 text-info"></i>Users</a></li>
                                        <li><a class="dropdown-item" asp-controller="Appointment" asp-action="Index"><i class="bi bi-calendar-check me-2 text-info"></i>Appointments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Invoice" asp-action="Index"><i class="bi bi-cash-stack me-2 text-info"></i>Invoices</a></li>
                                    }
                                    else if (User.IsInRole(SD.Doctor))
                                    {
                                        <li><a class="dropdown-item" asp-controller="DoctorSchedule" asp-action="Index"><i class="bi bi-calendar3 me-2 text-info"></i>My Schedule</a></li>
                                        <li><a class="dropdown-item" asp-controller="DoctorAppointments" asp-action="Index"><i class="bi bi-calendar2-range me-2 text-info"></i>Patient Appointments</a></li>
                                        <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-person-circle me-2 text-info"></i>Profile</a></li>
                                    }
                                    else if (User.IsInRole(SD.Patient))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Appointment" asp-action="Index"><i class="bi bi-calendar-event me-2 text-info"></i>My Appointments</a></li>
                                        <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-person-circle me-2 text-info"></i>Profile</a></li>
                                    }
                                </ul>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                    <button type="submit" class="nav-link btn btn-link border-0 align-baseline text-white d-flex align-items-center p-0"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register"><i class="bi bi-person-plus me-1"></i>Register</a></li>
                            <li class="nav-item"><a class="nav-link ms-lg-2 btn btn-neon-cyan px-3 py-1 text-dark" style="color: #020710 !important;" asp-area="Identity" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <nav aria-label="breadcrumb"></nav>
        <main role="main" class="pb-3">
            @if (TempData["success"] != null)
            {
                <partial name="_StatusMessage" model='TempData["success"].ToString()' />
            }
            else if (TempData["error"] != null)
            {
                <partial name="_StatusMessage" model='TempData["error"].ToString()' />
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>