@{
    ViewData["Title"] = "Admin Dashboard";
    var upcomingAppointments = ViewBag.UpcomingAppointments as IEnumerable<Models.Appointment> ?? new List<Models.Appointment>();
    var latestDoctors = ViewBag.LatestDoctors as IEnumerable<Models.Doctor> ?? new List<Models.Doctor>();
    var latestPatients = ViewBag.LatestPatients as IEnumerable<Models.Patient> ?? new List<Models.Patient>();
    var latestNotifications = ViewBag.LatestNotifications as IEnumerable<Models.Notification> ?? new List<Models.Notification>();
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h1 class="font-weight-bold mb-0" style="color: #ffffff; text-shadow: 0 0 15px rgba(0, 240, 255, 0.6), 0 2px 4px rgba(0,0,0,0.8);">
            <i class="bi bi-speedometer2 me-2 text-info"></i>DentCare Control Center
        </h1>
        <span class="badge bg-dark border border-info p-2 text-info font-weight-bold"><i class="bi bi-clock me-1"></i>System Active</span>
    </div>

    <div class="row g-3 my-2">
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-building text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Clinics</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.ClinicsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-person-badge text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Doctors</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.DoctorsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-people text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Total Patients</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.PatientsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-diagram-3 text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Departments</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.DepartmentsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-activity text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Treatments</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.TreatmentsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.3);">
                <i class="bi bi-calendar-check text-info fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Total Appts</small>
                <h3 class="mb-0 text-white font-weight-bold">@ViewBag.AppointmentsCount</h3>
            </div>
        </div>
    </div>

    <div class="row g-3 my-2">
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-calendar-day text-warning fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Today's Appts</small>
                <h3 class="mb-0 text-warning font-weight-bold">@ViewBag.TodayAppointmentsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-calendar-x text-danger fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Cancelled Appts</small>
                <h3 class="mb-0 text-danger font-weight-bold">@ViewBag.CancelledAppointmentsCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-check-circle text-success fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Paid Invoices</small>
                <h3 class="mb-0 text-success font-weight-bold">@ViewBag.PaidInvoicesCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-exclamation-circle text-warning fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Unpaid Invoices</small>
                <h3 class="mb-0 text-warning font-weight-bold">@ViewBag.UnpaidInvoicesCount</h3>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-cash text-success fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Revenue Today</small>
                <h4 class="mb-0 text-success font-weight-bold">@($"{ViewBag.RevenueToday:N0}")</h4>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="p-3 rounded h-100 text-center" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.15);">
                <i class="bi bi-graph-up-arrow text-success fs-3 d-block mb-1"></i>
                <small class="text-muted d-block text-uppercase font-weight-bold" style="font-size: 0.75rem;">Rev This Month</small>
                <h4 class="mb-0 text-success font-weight-bold">@($"{ViewBag.RevenueThisMonth:N0}")</h4>
            </div>
        </div>
    </div>

    <div class="row g-4 my-3">
        <div class="col-lg-4">
            <div class="p-4 rounded h-100" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="text-white mb-3 font-weight-bold"><i class="bi bi-bar-chart-line me-2 text-info"></i>Monthly Appointments</h5>
                <canvas id="appointmentsBarChart" height="220"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="p-4 rounded h-100" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="text-white mb-3 font-weight-bold"><i class="bi bi-pie-chart me-2 text-info"></i>Appointment Status</h5>
                <canvas id="statusPieChart" height="220"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="p-4 rounded h-100" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="text-white mb-3 font-weight-bold"><i class="bi bi-graph-up me-2 text-success"></i>Monthly Revenue Line</h5>
                <canvas id="revenueLineChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <div class="row g-4 my-3">
        <div class="col-lg-12">
            <div class="p-4 rounded" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-white font-weight-bold mb-0"><i class="bi bi-calendar2-range me-2 text-info"></i>Upcoming Patient Appointments</h5>
                    <a href="/Appointment/Index" class="btn btn-sm btn-outline-info font-weight-bold"><i class="bi bi-eye me-1"></i>View All</a>
                </div>
                @if (upcomingAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover border-0 mb-0" style="background: transparent;">
                            <thead>
                                <tr class="text-info" style="border-bottom: 2px solid rgba(0,229,255,0.2);">
                                    <th>Patient</th>
                                    <th>Doctor</th>
                                    <th>Clinic Branch</th>
                                    <th>Schedule</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in upcomingAppointments)
                                {
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <td class="text-white font-weight-bold">@(appt.Patient?.User?.FullName ?? "Anonymous")</td>
                                        <td class="text-white-50">Dr. @(appt.Doctor?.User?.FullName ?? "Unknown")</td>
                                        <td>@appt.Clinic?.Name</td>
                                        <td>
                                            <small class="d-block text-info">@appt.AppointmentDate.ToString("yyyy-MM-dd")</small>
                                            <small class="text-muted">@appt.AppointmentTime.ToString(@"hh\:mm")</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-opacity-25 p-2 @(appt.Status == "Confirmed" ? "bg-success text-success" : "bg-warning text-warning")" style="border: 1px solid rgba(255,255,255,0.1);">
                                                @appt.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-center text-muted py-4 mb-0">No upcoming appointments tracked for today.</p>
                }
            </div>
        </div>
    </div>

    <div class="row g-4 my-3">
        <div class="col-lg-6">
            <div class="p-4 rounded h-100" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="text-white mb-3 font-weight-bold"><i class="bi bi-people-fill me-2 text-info"></i>Newly Onboarded Specialists</h5>
                @if (latestDoctors.Any())
                {
                    <ul class="list-group list-group-flush bg-transparent">
                        @foreach (var doc in latestDoctors)
                        {
                            <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                                <div>
                                    <h6 class="text-white font-weight-bold mb-0">Dr. @(doc.User?.FullName ?? "Unknown Doctor")</h6>
                                    <small class="text-info">@doc.Specialization</small>
                                </div>
                                <span class="badge rounded-pill bg-dark border border-info text-muted">Exp: @doc.ExperienceYears Yrs</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-center text-muted py-4 mb-0">No newly onboarded specialists recorded.</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="p-4 rounded h-100" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="text-white mb-3 font-weight-bold"><i class="bi bi-person-heart me-2 text-info"></i>Latest Registered Patients</h5>
                @if (latestPatients.Any())
                {
                    <ul class="list-group list-group-flush bg-transparent">
                        @foreach (var pt in latestPatients)
                        {
                            <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                                <div>
                                    <h6 class="text-white font-weight-bold mb-0">@(pt.User?.FullName ?? "Anonymous Patient")</h6>
                                    <small class="text-muted">Blood Type: @(pt.BloodType ?? "N/A")</small>
                                </div>
                                <span class="badge rounded-pill bg-dark border border-secondary text-info">@pt.Gender</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-center text-muted py-4 mb-0">No newly registered patients recorded.</p>
                }
            </div>
        </div>
    </div>

    <div class="p-4 rounded my-4" style="background: rgba(1, 4, 8, 0.9); border: 1px solid rgba(255,255,255,0.05);">
        <h4 class="text-white mb-3 font-weight-bold"><i class="bi bi-bell-fill me-2 text-warning"></i>Recent System Activity Log Notifications</h4>
        @if (latestNotifications.Any())
        {
            <div class="list-group bg-transparent">
                @foreach (var notif in latestNotifications)
                {
                    <div class="list-group-item bg-transparent text-white border-0 border-start border-info border-3 mb-2 p-3" style="background: rgba(255,255,255,0.02) !important;">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1 font-weight-bold text-white">@notif.Title</h6>
                            <small class="text-muted">@notif.CreatedAt.ToString("g")</small>
                        </div>
                        <p class="mb-0 text-muted small">@notif.Message</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted py-3 mb-0">System logs are clean. No recent system operations broadcasted.</p>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const monthsLabels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

        // 1. Appointments Bar Chart
        new Chart(document.getElementById('appointmentsBarChart'), {
        type: 'bar',
        data: {
        labels: monthsLabels,
        datasets: [{
        label: 'Appointments',
        data: @Html.Raw(Json.Serialize(ViewBag.ChartAppointmentMonths)),
        backgroundColor: 'rgba(0, 229, 255, 0.6)',
        borderColor: 'rgba(0, 229, 255, 1)',
        borderWidth: 1
        }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });

        // 2. Status Pie Chart
        new Chart(document.getElementById('statusPieChart'), {
        type: 'pie',
        data: {
        labels: ['Confirmed', 'Pending', 'Cancelled'],
        datasets: [{
        data: [@ViewBag.ChartConfirmedCount, @ViewBag.ChartPendingCount, @ViewBag.ChartCancelledCount],
        backgroundColor: ['rgba(40, 167, 69, 0.6)', 'rgba(255, 193, 7, 0.6)', 'rgba(220, 53, 69, 0.6)'],
        borderColor: ['#28a745', '#ffc107', '#dc3545'],
        borderWidth: 1
        }]
        },
        options: { responsive: true }
        });

        // 3. Revenue Line Chart
        new Chart(document.getElementById('revenueLineChart'), {
        type: 'line',
        data: {
        labels: monthsLabels,
        datasets: [{
        label: 'Revenue (EGP)',
        data: @Html.Raw(Json.Serialize(ViewBag.ChartRevenueMonths)),
        backgroundColor: 'rgba(40, 167, 69, 0.1)',
        borderColor: 'rgba(40, 167, 69, 1)',
        borderWidth: 2,
        tension: 0.3,
        fill: true
        }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}