@model Models.Clinic
@{
    ViewData["Title"] = "Clinic Details";
    var appointments = ViewBag.Appointments as IEnumerable<Models.Appointment> ?? new List<Models.Appointment>();
}

<div class="glass-card">
    <div class="row align-items-center mb-4">
        <div class="col-md-2 text-center">
            <div class="mx-auto" style="width: 100px; height: 100px; border-radius: 50%; border: 2px solid #00e5ff; overflow: hidden; background: rgba(255,255,255,0.05);">
                @if (!string.IsNullOrEmpty(Model.Logo))
                {
                    <img src="~/images/clinics/@Model.Logo" style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    <i class="bi bi-building text-muted d-block mt-3" style="font-size: 3rem;"></i>
                }
            </div>
        </div>
        <div class="col-md-10 text-center text-md-start mt-3 mt-md-0">
            <h2 class="glass-title mb-1">@Model.Name</h2>
            <p class="text-info mb-0">Subscription Plan: <span class="badge bg-dark border border-info text-info">@Model.SubscriptionPlan</span></p>
        </div>
    </div>

    <hr style="border-color: rgba(0,229,255,0.15);" />

    <div class="row g-4 mt-2">
        <div class="col-md-6">
            <h5 class="text-info mb-3"><i class="bi bi-info-circle me-2"></i>Contact Information</h5>
            <p><strong class="text-muted">Address:</strong> @Model.Address</p>
            <p><strong class="text-muted">Phone Number:</strong> @Model.Phone</p>
            <p><strong class="text-muted">Email:</strong> @(Model.Email ?? "N/A")</p>
            <p><strong class="text-muted">Working Hours:</strong> @(Model.WorkingHours ?? "N/A")</p>
        </div>
        <div class="col-md-6">
            <h5 class="text-info mb-3"><i class="bi bi-card-text me-2"></i>Description</h5>
            <p class="text-light" style="line-height: 1.6;">@(Model.Description ?? "No core description shared for this branch.")</p>
        </div>
    </div>

    <hr style="border-color: rgba(0,229,255,0.15);" class="my-4" />

    <h3 class="text-white font-weight-bold mb-3"><i class="bi bi-calendar-check me-2"></i>Clinic Appointments</h3>
    <div class="table-responsive">
        <table class="table text-white" style="background: rgba(3,10,16,0.4); border-radius: 8px; overflow: hidden;">
            <thead>
                <tr style="border-bottom: 2px solid rgba(0,229,255,0.25); background: rgba(0,0,0,0.2);">
                    <th class="p-3">Patient Name</th>
                    <th class="p-3">Assigned Doctor</th>
                    <th class="p-3">Appointment Date</th>
                    <th class="p-3">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!appointments.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted p-4">No schedules or active logs tracked for this clinic.</td>
                    </tr>
                }
                else
                {
                    @foreach (var app in appointments)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td class="p-3">@app.Patient?.User?.FullName</td>
                            <td class="p-3">Dr. @app.Doctor?.User?.FullName</td>
                            <td class="p-3">@app.AppointmentDate.ToString("yyyy-MM-dd hh:mm tt")</td>
                            <td class="p-3">
                                <span class="badge @(app.Status == "Confirmed" ? "bg-success" : "bg-warning")">@app.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.ClinicId" class="btn btn-neon-cyan px-4 py-2">Edit Clinic</a>
        <a asp-action="Index" class="btn btn-neon-cancel px-4 py-2">Back to List</a>
    </div>
</div>