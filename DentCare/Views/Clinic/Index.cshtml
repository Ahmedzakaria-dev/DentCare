@model IEnumerable<Models.Clinic>
@{
    ViewData["Title"] = "Clinics Management";
    int currentPage = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    List<int> busyClinics = ViewBag.BusyClinicsIds;
}

<div class="glass-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="glass-title mb-0"><i class="bi bi-hospital me-2"></i>Clinics Registered</h2>
            <p class="text-muted small mb-0">Manage system dental clinics, plans, and branch status.</p>
        </div>
        <a asp-action="Create" class="btn btn-neon-cyan px-4 py-2"><i class="bi bi-plus-circle me-2"></i>Add New Clinic</a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 position-relative" style="background: rgba(3, 10, 16, 0.6); border: 1px solid rgba(0, 229, 255, 0.15); border-radius: 12px; transition: transform 0.2s;">
                    
                    @if (busyClinics.Contains(item.ClinicId))
                    {
                        <span class="position-absolute top-0 end-0 m-3 badge" style="background: rgba(0, 240, 255, 0.2); color: #00f0ff; border: 1px solid #00f0ff;">
                            <i class="bi bi-fire me-1"></i> Top Busy
                        </span>
                    }

                    <div class="card-body text-center pt-4">
                        <div class="mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: rgba(255,255,255,0.03); border-radius: 50%; border: 1px solid rgba(0,229,255,0.2);">
                            @if (!string.IsNullOrEmpty(item.Logo))
                            {
                                <img src="~/images/clinics/@item.Logo" class="img-fluid rounded-circle" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-building text-info" style="font-size: 2rem;"></i>
                            }
                        </div>

                        <h4 class="text-white font-weight-bold mb-1">@item.Name</h4>
                        <span class="badge mb-3" style="background: rgba(255,255,255,0.1); color: #ccc;">@item.SubscriptionPlan Plan</span>
                        
                        <p class="text-muted small text-start"><i class="bi bi-geo-alt-fill text-info me-2"></i>@item.Address</p>
                        <p class="text-muted small text-start"><i class="bi bi-telephone-fill text-info me-2"></i>@item.Phone</p>
                    </div>

                    <div class="card-footer bg-transparent border-0 d-flex gap-2 p-3">
                        <a asp-action="Details" asp-route-id="@item.ClinicId" class="btn btn-outline-info btn-sm flex-grow-1"><i class="bi bi-eye"></i> Details</a>
                        <a asp-action="Edit" asp-route-id="@item.ClinicId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.ClinicId" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" style="background: transparent; border-color: rgba(0,229,255,0.2); color: #fff;" asp-action="Index" asp-route-page="@(currentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" style="@(currentPage == i ? "background: #00b4db; border-color: #00b4db;" : "background: transparent; border-color: rgba(0,229,255,0.2); color: #fff;")" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" style="background: transparent; border-color: rgba(0,229,255,0.2); color: #fff;" asp-action="Index" asp-route-page="@(currentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>