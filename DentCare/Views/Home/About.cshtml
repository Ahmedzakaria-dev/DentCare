@{
    ViewData["Title"] = "About Us";
}

<div class="glass-card mt-4 p-5 text-center">
    <h2 class="glass-title mb-4"><i class="bi bi-building-check me-2"></i>About DentCare Network</h2>
    <p class="lead text-muted mx-auto" style="max-width: 800px; line-height: 1.8;">
        DentCare is an integrated ecosystem specialized in connecting premium dental clinic branches with top tier medical practitioners and patients, leveraging high end cloud capabilities to ensure maximum health security, logging efficiency, and seamless transaction workflows.
    </p>

    <div class="row g-4 mt-5 justify-content-center">
        <div class="col-sm-4">
            <div class="p-3 rounded" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.2);">
                <h3 class="text-white font-weight-bold mb-0">@ViewBag.ClinicsCount</h3>
                <small class="text-info font-weight-bold">Active Branches</small>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="p-3 rounded" style="background: rgba(1, 4, 8, 0.88); border: 1px solid rgba(0, 229, 255, 0.2);">
                <h3 class="text-white font-weight-bold mb-0">@ViewBag.DoctorsCount</h3>
                <small class="text-info font-weight-bold">Certified Consultants</small>
            </div>
        </div>
    </div>
</div>